<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task List Aesthetic</title>
    <style>
        /* Estilo Apple + Aesthetic Vibrante */
        :root {
            --glass-bg: rgba(255, 255, 255, 0.25);
            --glass-border: rgba(255, 255, 255, 0.4);
            --glass-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.37);
            
            --pri-alta: #ff2a5f;
            --pri-media: #ff9f0a;
            --pri-baixa: #32d74b;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            /* Fundo gradiente vibrante animado */
            background: linear-gradient(45deg, #ff00cc, #333399, #00c9ff, #92fe9d);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            color: #1d1d1f;
        }

        @keyframes gradientBG {
            0% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
            100% { background-position: 0% 50%; }
        }

        .container {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            box-shadow: var(--glass-shadow);
            width: 100%;
            max-width: 500px;
            padding: 30px;
        }

        h1 {
            text-align: center;
            color: white;
            margin-bottom: 25px;
            font-weight: 600;
            letter-spacing: 0.5px;
            text-shadow: 0 2px 4px rgba(0,0,0,0.2);
        }

        .input-group {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
        }

        input[type="text"], select, button {
            border: none;
            outline: none;
            padding: 12px 15px;
            border-radius: 12px;
            background: rgba(255, 255, 255, 0.6);
            backdrop-filter: blur(10px);
            font-size: 16px;
            transition: all 0.3s ease;
        }

        input[type="text"] {
            flex-grow: 1;
        }

        input[type="text"]:focus, select:focus {
            background: rgba(255, 255, 255, 0.9);
            box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.5);
        }

        button {
            background: rgba(255, 255, 255, 0.9);
            font-weight: bold;
            cursor: pointer;
            color: #1d1d1f;
        }

        button:hover {
            transform: scale(1.05);
            background: #fff;
        }

        ul {
            list-style: none;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        li {
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(10px);
            padding: 15px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 15px;
            transition: transform 0.2s ease, opacity 0.3s ease;
            border: 1px solid rgba(255,255,255,0.2);
        }

        li:hover {
            transform: translateY(-2px);
            background: rgba(255, 255, 255, 0.7);
        }

        .task-content {
            display: flex;
            align-items: center;
            gap: 15px;
            flex-grow: 1;
            word-break: break-word;
        }

        .checkbox {
            width: 20px;
            height: 20px;
            cursor: pointer;
            accent-color: #1d1d1f;
        }

        .task-text {
            font-size: 16px;
            font-weight: 500;
        }

        .completed .task-text {
            text-decoration: line-through;
            opacity: 0.5;
        }

        .priority-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .p-alta { background-color: var(--pri-alta); box-shadow: 0 0 8px var(--pri-alta); }
        .p-media { background-color: var(--pri-media); box-shadow: 0 0 8px var(--pri-media); }
        .p-baixa { background-color: var(--pri-baixa); box-shadow: 0 0 8px var(--pri-baixa); }

        .actions {
            display: flex;
            gap: 8px;
        }

        .actions select {
            padding: 5px 8px;
            font-size: 12px;
            background: rgba(255, 255, 255, 0.4);
        }

        .btn-delete {
            background: rgba(255, 59, 48, 0.2);
            color: #ff3b30;
            padding: 8px 12px;
        }

        .btn-delete:hover {
            background: #ff3b30;
            color: white;
        }
    </style>
</head>
<body>

    <div class="container">
        <h1>Minhas Tarefas</h1>
        
        <div class="input-group">
            <input type="text" id="taskInput" placeholder="O que você precisa fazer?" onkeypress="handleKeyPress(event)">
            <select id="priorityInput">
                <option value="alta">Alta</option>
                <option value="media" selected>Média</option>
                <option value="baixa">Baixa</option>
            </select>
            <button onclick="addTask()">Adicionar</button>
        </div>

        <ul id="taskList">
            <!-- As tarefas aparecerão aqui -->
        </ul>
    </div>

    <script>
        // Lógica principal usando LocalStorage
        let tasks = JSON.parse(localStorage.getItem('@AppleTasks')) || [];

        const taskInput = document.getElementById('taskInput');
        const priorityInput = document.getElementById('priorityInput');
        const taskList = document.getElementById('taskList');

        // Função para atualizar o LocalStorage e a Tela
        function saveAndRender() {
            localStorage.setItem('@AppleTasks', JSON.stringify(tasks));
            renderTasks();
        }

        function addTask() {
            const text = taskInput.value.trim();
            if (!text) return;

            const newTask = {
                id: Date.now(),
                text: text,
                priority: priorityInput.value,
                completed: false
            };

            // Adiciona no início da lista
            tasks.unshift(newTask);
            taskInput.value = '';
            
            saveAndRender();
        }

        function handleKeyPress(event) {
            if (event.key === 'Enter') {
                addTask();
            }
        }

        function deleteTask(id) {
            tasks = tasks.filter(task => task.id !== id);
            saveAndRender();
        }

        function toggleComplete(id) {
            tasks = tasks.map(task => {
                if (task.id === id) {
                    return { ...task, completed: !task.completed };
                }
                return task;
            });
            saveAndRender();
        }

        function changePriority(id, newPriority) {
            tasks = tasks.map(task => {
                if (task.id === id) {
                    return { ...task, priority: newPriority };
                }
                return task;
            });
            saveAndRender();
        }

        function renderTasks() {
            taskList.innerHTML = '';

            tasks.forEach(task => {
                const li = document.createElement('li');
                if (task.completed) li.classList.add('completed');

                li.innerHTML = `
                    <div class="task-content">
                        <input type="checkbox" class="checkbox" ${task.completed ? 'checked' : ''} onchange="toggleComplete(${task.id})">
                        <div class="priority-indicator p-${task.priority}"></div>
                        <span class="task-text">${task.text}</span>
                    </div>
                    <div class="actions">
                        <select onchange="changePriority(${task.id}, this.value)">
                            <option value="alta" ${task.priority === 'alta' ? 'selected' : ''}>Alta</option>
                            <option value="media" ${task.priority === 'media' ? 'selected' : ''}>Média</option>
                            <option value="baixa" ${task.priority === 'baixa' ? 'selected' : ''}>Baixa</option>
                        </select>
                        <button class="btn-delete" onclick="deleteTask(${task.id})">✕</button>
                    </div>
                `;
                taskList.appendChild(li);
            });
        }

        // Renderiza as tarefas ao carregar a página
        renderTasks();
    </script>
</body>
</html>
